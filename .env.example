# Copy to `.env` and fill in values. Never commit `.env`.
# If upgrading from a broken file, ensure each variable is on its own line (no concatenated keys).

# Model providers (use the keys required by your agent models)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Supabase (Auth + Postgres)
SUPABASE_URL=
# Same project URL as above if you only set one
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only: seed script (scripts/seed.ts) and admin APIs — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=
# Supabase CLI: run `pnpm supabase:link` after `supabase login` (or set token below)
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=vnqokeemyxzsyiotamys

# Postgres connection string (Supabase; Mastra @mastra/pg storage uses DATABASE_URL)
DATABASE_URL=

# Mastra Studio / mastra dev: org UUID for tools that require orgId (match seeded `organizations.id` after pnpm run seed)
# MASTRA_STUDIO_ORG_ID=

# Demo seed: pnpm run seed (creates auth users; min 6 characters)
SEED_DEMO_PASSWORD=

# Optional Mastra Cloud (observability exporter)
# MASTRA_CLOUD_ACCESS_TOKEN=

# Nango (Integration Handler)
NANGO_SECRET_KEY=          
# NANGO_SERVER_URL=https://api.nango.dev   # optional; default cloud

# Nango BYO spike only (scripts/nango-tests/nango-byo-spike.ts) — dev/manual; never commit real secrets
# NANGO_SPIKE_ORG_ID=                      # org UUID for spike tags (e.g. seeded org after pnpm run seed)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# NANGO_SPIKE_END_USER_EMAIL=              # Workspace test user allowed by your Internal OAuth app