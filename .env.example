# Copy to `.env` and fill in values. Never commit `.env`.
# If upgrading from a broken file, ensure each variable is on its own line (no concatenated keys).

# Model providers (use the keys required by your agent models)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Supabase (Auth + Postgres; used in later bootstrap phases)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string (Mastra storage / tooling in later phases)
DATABASE_URL=

# Optional Mastra / local dev (see src/mastra/index.ts)
# MASTRA_DUCKDB_PATH=
# MASTRA_CLOUD_ACCESS_TOKEN=
