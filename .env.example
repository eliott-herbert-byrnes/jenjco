# Copy to `.env` and fill in values. Never commit `.env`.
# If upgrading from a broken file, ensure each variable is on its own line (no concatenated keys).

# Model providers (use the keys required by your agent models)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Supabase (Auth + Postgres)
SUPABASE_URL=
# Same project URL as above if you only set one
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only: seed script (scripts/seed.ts) and admin APIs — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string (Supabase; Mastra @mastra/pg storage uses DATABASE_URL)
DATABASE_URL=

# Mastra Studio / mastra dev: org UUID for tools that require orgId (match seeded `organizations.id` after pnpm run seed)
# MASTRA_STUDIO_ORG_ID=

# Demo seed: pnpm run seed (creates auth users; min 6 characters)
SEED_DEMO_PASSWORD=

# Optional Mastra Cloud (observability exporter)
# MASTRA_CLOUD_ACCESS_TOKEN=
